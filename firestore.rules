rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return request.auth.token.admin == true;
    }

    // Jobs — users can only access their own
    match /jobs/{jobId} {
      allow read: if isAuthenticated() && isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId);
      allow update: if isAuthenticated() && isOwner(resource.data.userId);
      allow delete: if isAdmin();
    }

    // Error logs — admin read only; writes blocked from client
    match /error_logs/{errorId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Performance logs — admin only
    match /performance_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Job metrics — authenticated users can read; writes reserved for system
    match /job_metrics/{metricId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Uploads — users can only access their own
    match /uploads/{uploadId} {
      allow read: if isAuthenticated() && isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId);
      allow update: if isAuthenticated() && isOwner(resource.data.userId);
      allow delete: if isAuthenticated() && isOwner(resource.data.userId);
    }

    // User profiles — owner access only
    match /users/{userId} {
      allow read, create, update: if isOwner(userId);
      allow delete: if isAdmin();
    }

    // Completed video outputs — public read
    match /video_outputs/{videoId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
